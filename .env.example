POSTGRES_DB=senti
POSTGRES_USER=senti
POSTGRES_PASSWORD=senti_password
DATABASE_URL=postgres://senti:senti_password@postgres:5432/senti?sslmode=disable
HTTP_ADDR=:8080
CORS_ORIGIN=http://localhost
UPLOAD_DIR=/app/uploads
TEMP_UPLOAD_DIR=/app/uploads/tmp
CHAT_SKILLS_DIR=/app/chat-skills
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
OCR_LANG=chi_sim+eng
# Seeded into invite_codes at backend startup. Each code can register one account.
INVITE_CODE=change-me
AUTH_TOKEN_SECRET=change-this-long-random-secret
ANALYZE_TIMEOUT=60s
RATE_LIMIT_WINDOW=24h
RATE_LIMIT_REQUESTS=15
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
